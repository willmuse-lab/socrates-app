# Copy this file to ".env" for local development, and set the same variables
# in Netlify (Site configuration → Environment variables) for production.
# VITE_* variables are read at BUILD time and inlined into the frontend.

# ── Required: the AI analyzer ───────────────────────────────────────────────
# Server-side only (used by the Netlify function). Get one at console.anthropic.com.
ANTHROPIC_API_KEY=

# ── Optional: real accounts, cloud save, and the Research Library ────────────
# Without these two, the app runs in local/demo mode (browser-only, fake admin
# data, no persisted research uploads). With them, accounts and sync are real.
# Find both in your Supabase project: Settings → API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Optional: admin area password ───────────────────────────────────────────
# Gates the Admin Dashboard / Research Library. NOTE: this is bundled into the
# frontend and is therefore visible to anyone who inspects the site — treat it
# as a soft gate, not real security. Defaults to "socrates2025" if unset.
VITE_ADMIN_PASSWORD=
